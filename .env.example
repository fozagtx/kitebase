# kitebase env template. Copy to .env and fill in the values.

# ---- Auth / persistence ----
COOKIE_SECRET=please-change-me-to-a-long-random-string
COOKIE_NAME=hc_session
DB_PATH=./hermesCloud.sqlite
SESSION_TTL_DAYS=30
PORT=3001
LOG_LEVEL=info

# Public URL of this control plane. When set, each deployed VPS installs a
# kitebase-sync timer that pulls channel config (Telegram tokens etc.) every
# minute, enabling hot-reload without redeploying actors.
# Leave unset for local-only dev.
# PUBLIC_BASE_URL=https://kitebase.example.com

# ---- Kite chain ----
KITE_NETWORK=testnet

# ---- Featherless inference (used by deployed actors) ----
# Get a key at https://featherless.ai
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=NousResearch/Hermes-3-Llama-3.1-8B

# ---- Kite MCP (optional, per-deployment) ----
# KITE_MCP_BASE=https://mcp.prod.gokite.ai
# KITE_MCP_API_KEY=

# ---- Vultr (REQUIRED for real VPS deploys) ----
# Get a Personal Access Token at https://my.vultr.com/settings/#settingsapi
# Without this, deploys are stored as "pending" with cloud-init prepared.
VULTR_API_KEY=
VULTR_REGION=ewr
VULTR_PLAN=vc2-1c-1gb
VULTR_OS_ID=2284

# ---- Kite platform passport (one-passport model) ----
# Generate with:  bun -e "console.log('0x'+require('node:crypto').randomBytes(32).toString('hex'))"
# Then fund the resulting EOA on https://faucet.gokite.ai so the platform can pay AA gas.
# REQUIRED. Every deployed actor derives its AA wallet from this EOA.
KITE_OPERATOR_PRIVATE_KEY=
KITE_OPERATOR_LABEL=kitebase
